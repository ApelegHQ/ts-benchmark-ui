{
	"name": "@apeleghq/benchmark-ui",
	"version": "1.0.6",
	"description": "A statistically rigorous benchmarking library with paired t-tests, baseline correction, and confidence intervals",
	"homepage": "https://benchmarkstudio.net/",
	"type": "module",
	"devDependencies": {
		"@apeleghq/benchmark": "1.0.6",
		"@apeleghq/esbuild-plugin-closure-compiler": "^1.0.11",
		"@codemirror/lang-javascript": "6.2.5",
		"@codemirror/state": "6.5.4",
		"@codemirror/view": "6.39.16",
		"@eslint/eslintrc": "3.3.4",
		"@eslint/js": "10.0.1",
		"@sveltejs/vite-plugin-svelte": "6.2.1",
		"@tsconfig/svelte": "5.0.6",
		"@types/google-closure-compiler": "^20231112.0.0",
		"@types/html-minifier-terser": "7.0.2",
		"@types/node": "24.10.1",
		"@types/postcss-functions": "^4.0.4",
		"@typescript-eslint/eslint-plugin": "8.56.1",
		"@typescript-eslint/parser": "8.56.1",
		"codemirror": "6.0.2",
		"cssnano": "^7.1.3",
		"eslint": "10.0.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-svelte": "3.15.0",
		"globals": "17.4.0",
		"html-minifier-terser": "7.2.0",
		"postcss-functions": "^4.0.2",
		"postcss-nesting": "^14.0.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.0",
		"svelte": "^5.53.7",
		"svelte-check": "4.3.4",
		"svelte-eslint-parser": "1.5.1",
		"typescript": "~5.9.3",
		"vite": "7.3.1",
		"vite-plugin-sri-gen": "1.3.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ApelegHQ/ts-benchmark-ui.git"
	},
	"files": [
		"dist/**/*"
	],
	"scripts": {
		"lint": "eslint . --ext .svelte,.cjs,.cts,.mjs,.mjs,.js,.ts,.json",
		"lint:fix": "prettier -w . && eslint . --ext .svelte,.cjs,.cts,.mjs,.mjs,.js,.ts,.json --fix",
		"dev": "vite",
		"build": "vite build",
		"build:es": "LOCALE=es vite build",
		"build:all": "vite build && LOCALE=es vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"prepack": "npm run build",
		"prepublishOnly": "npm test && npm run lint",
		"preversion": "npm run lint",
		"version": "npm run lint && git add -A src",
		"postversion": "git push && git push --tags"
	},
	"author": "Apeleg Limited",
	"license": "AGPL-3.0-only",
	"keywords": [
		"benchmark",
		"benchmarking",
		"performance",
		"statistics",
		"paired-t-test",
		"confidence-interval",
		"profiling",
		"timing",
		"measurement",
		"statistical-analysis"
	]
}
